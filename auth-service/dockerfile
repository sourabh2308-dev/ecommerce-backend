# ═══════════════════════════════════════════════════════════════════════════════
# MULTI-STAGE DOCKERFILE FOR AUTH-SERVICE MICROSERVICE
# ═══════════════════════════════════════════════════════════════════════════════
#
# PURPOSE:
# Creates optimized Docker image for auth-service using multi-stage build pattern.
# Separates build environment from runtime environment to minimize final image size.
#
# STAGES:
# 1. Builder Stage: Compiles Java source code and packages JAR file
# 2. Runtime Stage: Runs the application with minimal dependencies
#
# BENEFITS:
# - Smaller image size (only JRE + JAR, no Maven or source code)
# - Faster deployment (less data to transfer)
# - Better security (no build tools in production image)
# - Layer caching (dependencies cached separately from source)
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# STAGE 1: BUILD STAGE
# ─────────────────────────────────────────────────────────────────────────────
# Base image: Maven 3.9 with Eclipse Temurin JDK 17 on Alpine Linux
# AS builder: Names this stage for reference in later COPY --from=builder
# Alpine: Minimal Linux distro (~5MB base, vs ~100MB for Ubuntu)
FROM maven:3.9-eclipse-temurin-17-alpine AS builder

# Set working directory for all subsequent commands in this stage
# All files will be copied/created here: /workspace
WORKDIR /workspace

# ─────────────────────────────────────────────────────────────────────────────
# DEPENDENCY RESOLUTION (Cached Layer)
# ─────────────────────────────────────────────────────────────────────────────
# WHY: Copy pom.xml files first to leverage Docker layer caching.
# If pom.xml doesn't change, Maven won't re-download dependencies on rebuild.
# This dramatically speeds up builds during development.

# Copy root pom.xml (parent POM with dependency management)
COPY pom.xml .

# Copy all module pom.xml files (multi-module Maven project structure)
# Even though we only build auth-service, Maven needs all POMs to resolve the reactor
COPY api-gateway/pom.xml api-gateway/
COPY auth-service/pom.xml auth-service/
COPY auth-service/pom.xml auth-service/
COPY product-service/pom.xml product-service/
COPY order-service/pom.xml order-service/
COPY review-service/pom.xml review-service/
COPY payment-service/pom.xml payment-service/
COPY eureka-server/pom.xml eureka-server/
COPY config-server/pom.xml config-server/

# Download all dependencies for auth-service module
# -pl auth-service: Build only this module
# dependency:go-offline: Downloads dependencies to local .m2 repository
# -B: Batch mode (non-interactive, cleaner logs)
# --no-transfer-progress: Suppresses download progress (cleaner logs in CI/CD)
# || true: Don't fail build if some deps unavailable (optional deps)
RUN mvn -pl auth-service dependency:go-offline -B --no-transfer-progress || true

# ─────────────────────────────────────────────────────────────────────────────
# SOURCE CODE COMPILATION
# ─────────────────────────────────────────────────────────────────────────────
# Copy source code (done AFTER dependency download for better caching)
# If source changes but dependencies don't, previous RUN layer is reused
COPY auth-service/src auth-service/src

# Compile and package the application
# -pl auth-service: Build this module only
# package: Executes compile -> test -> package lifecycle phases
# -DskipTests: Skips unit tests (faster build, tests run separately in CI/CD)
# -B --no-transfer-progress: Same flags as above for clean output
# Output: auth-service/target/auth-service-0.0.1-SNAPSHOT.jar (or similar)
RUN mvn -pl auth-service package -DskipTests -B --no-transfer-progress

# ─────────────────────────────────────────────────────────────────────────────
# STAGE 2: RUNTIME STAGE
# ─────────────────────────────────────────────────────────────────────────────
# Base image: Eclipse Temurin JRE 17 on Alpine Linux
# JRE-only (not JDK): Smaller image, only runtime components (no javac compiler)
# Temurin: OpenJDK distribution from Adoptium (free, production-ready)
# Alpine: Minimal Linux (~40MB runtime vs ~200MB for Debian-based images)
FROM eclipse-temurin:17-jre-alpine

# Set working directory in runtime container
WORKDIR /app

# ─────────────────────────────────────────────────────────────────────────────
# COPY APPLICATION JAR
# ─────────────────────────────────────────────────────────────────────────────
# --from=builder: Copy from build stage (not from host filesystem)
# /workspace/auth-service/target/*.jar: Maven output JAR file
# app.jar: Rename to generic name for consistent ENTRYPOINT
# This is the ONLY file needed from build stage (source code discarded)
COPY --from=builder /workspace/auth-service/target/*.jar app.jar

# ─────────────────────────────────────────────────────────────────────────────
# EXPOSE PORT
# ─────────────────────────────────────────────────────────────────────────────
# Documents that the container listens on port 8080
# Does NOT actually publish the port (that's done with -p in docker run or docker-compose)
# This is metadata for documentation and tools like docker ps
EXPOSE 8080

# ─────────────────────────────────────────────────────────────────────────────
# CONTAINER STARTUP COMMAND
# ─────────────────────────────────────────────────────────────────────────────
# ENTRYPOINT: Command that executes when container starts
# ["java", "-jar", "app.jar"]: Exec form (preferred over shell form)
# Exec form: Runs command directly without shell wrapper (PID 1 = Java process)
# Benefits: Proper signal handling (SIGTERM for graceful shutdown), faster startup
#
# JVM will read environment variables configured in docker-compose.yml:
#   - spring.datasource.url (PostgreSQL connection)
#   - spring.kafka.bootstrap-servers (Kafka connection)
#   - eureka.client.service-url (Service discovery)
#   - JWT secrets, Redis config, etc.
ENTRYPOINT ["java", "-jar", "app.jar"]

# ─────────────────────────────────────────────────────────────────────────────
# IMAGE SIZE OPTIMIZATION RESULTS:
# ─────────────────────────────────────────────────────────────────────────────
# Multi-stage build reduces image size:
# - Builder stage (discarded): ~500MB (Maven + JDK + dependencies + source)
# - Runtime stage (kept): ~150MB (JRE + JAR only)
# - Alternative (single-stage): ~500MB
# Savings: ~350MB per service (with 6 services = ~2GB saved)
#
# ─────────────────────────────────────────────────────────────────────────────
