# ==========================================================================
# Product Service - Multi-Stage Dockerfile
# ==========================================================================
# Builds an optimised Docker image for the product-service microservice.
#
# Stage 1 (builder) : Compiles Java source with Maven and packages a JAR.
# Stage 2 (runtime) : Runs the application on a minimal JRE-only image.
#
# Benefits of multi-stage:
#   - Final image ~150 MB (JRE + JAR) vs ~500 MB single-stage
#   - No build tools or source code in the production image
#   - Docker layer caching speeds up iterative rebuilds
# ==========================================================================

# --------------------------------------------------------------------------
# STAGE 1: BUILD
# Base: Maven 3.9 + Eclipse Temurin JDK 17 on Alpine Linux
# --------------------------------------------------------------------------
FROM maven:3.9-eclipse-temurin-17-alpine AS builder

WORKDIR /workspace

# Copy POM files first so dependency downloads can be cached independently
# of source-code changes.
COPY pom.xml .
COPY api-gateway/pom.xml api-gateway/
COPY auth-service/pom.xml auth-service/
COPY user-service/pom.xml user-service/
COPY product-service/pom.xml product-service/
COPY order-service/pom.xml order-service/
COPY review-service/pom.xml review-service/
COPY payment-service/pom.xml payment-service/
COPY eureka-server/pom.xml eureka-server/
COPY config-server/pom.xml config-server/

# Download dependencies for this module (cached unless POMs change)
RUN mvn -pl product-service dependency:go-offline -B --no-transfer-progress || true

# Copy source code and compile
COPY product-service/src product-service/src
RUN mvn -pl product-service package -DskipTests -B --no-transfer-progress

# --------------------------------------------------------------------------
# STAGE 2: RUNTIME
# Base: Eclipse Temurin JRE 17 on Alpine (no JDK, no Maven)
# --------------------------------------------------------------------------
FROM eclipse-temurin:17-jre-alpine

WORKDIR /app

# Copy only the packaged JAR from the build stage
COPY --from=builder /workspace/product-service/target/*.jar app.jar

# Document the port the service listens on (actual publishing via docker-compose)
EXPOSE 8080

# Start the application in exec form for proper signal handling (PID 1)
ENTRYPOINT ["java", "-jar", "app.jar"]
