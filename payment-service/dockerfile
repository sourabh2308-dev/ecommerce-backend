# ═══════════════════════════════════════════════════════════════════════════════
# DOCKERFILE — Payment Service (Multi-Stage Build)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Builds an optimised Docker image for the payment-service microservice using a
# two-stage approach:
#
#   Stage 1 (builder) — Maven + JDK 17 on Alpine
#     • Resolves dependencies (cached layer)
#     • Compiles Java source and packages the Spring Boot fat JAR
#
#   Stage 2 (runtime) — JRE 17 on Alpine
#     • Copies only the fat JAR from the builder stage
#     • Runs the application with the minimal JRE footprint
#
# Image size is reduced from ~500 MB (builder) to ~150 MB (runtime) because
# Maven, the JDK toolchain, and all intermediate artefacts are discarded.
#
# ═══════════════════════════════════════════════════════════════════════════════

# ---------------------------------------------------------------------------
# STAGE 1 — BUILD
# ---------------------------------------------------------------------------
# Maven 3.9 with Eclipse Temurin JDK 17 on Alpine Linux provides a complete
# build toolchain in a lightweight base image.
FROM maven:3.9-eclipse-temurin-17-alpine AS builder

# All subsequent commands operate relative to /workspace.
WORKDIR /workspace

# ---------------------------------------------------------------------------
# Dependency resolution (cached layer)
# ---------------------------------------------------------------------------
# Copying POM files first allows Docker to cache the expensive
# dependency-download step.  As long as the POMs do not change, rebuilds
# skip this layer entirely.

# Parent POM with shared dependency-management definitions
COPY pom.xml .

# Sibling module POMs required by the Maven reactor even though only
# payment-service is built here.
COPY api-gateway/pom.xml api-gateway/
COPY auth-service/pom.xml auth-service/
COPY user-service/pom.xml user-service/
COPY product-service/pom.xml product-service/
COPY order-service/pom.xml order-service/
COPY review-service/pom.xml review-service/
COPY payment-service/pom.xml payment-service/
COPY eureka-server/pom.xml eureka-server/
COPY config-server/pom.xml config-server/

# Download dependencies into the local Maven cache.  The '|| true' guard
# prevents a build failure when optional dependencies are unavailable.
RUN mvn -pl payment-service dependency:go-offline -B --no-transfer-progress || true

# ---------------------------------------------------------------------------
# Source compilation
# ---------------------------------------------------------------------------
# Source code is copied AFTER the dependency layer so that code-only changes
# do not invalidate the cached dependency download.
COPY payment-service/src payment-service/src

# Compile, run annotation processors, and package the Spring Boot fat JAR.
# Tests are skipped here; they run in a dedicated CI step.
RUN mvn -pl payment-service package -DskipTests -B --no-transfer-progress

# ---------------------------------------------------------------------------
# STAGE 2 — RUNTIME
# ---------------------------------------------------------------------------
# Eclipse Temurin JRE 17 on Alpine provides the smallest viable Java runtime.
FROM eclipse-temurin:17-jre-alpine

WORKDIR /app

# Copy the fat JAR produced by Stage 1.  The glob pattern picks up the
# versioned artefact regardless of the version string in pom.xml.
COPY --from=builder /workspace/payment-service/target/*.jar app.jar

# Document the port the Spring Boot application listens on.
EXPOSE 8080

# Start the application using exec form so that the JVM receives OS signals
# (SIGTERM) directly, enabling graceful shutdown.
ENTRYPOINT ["java", "-jar", "app.jar"]
