# ── Eureka Server Dockerfile ─────────────────────────────────────────────────
# Multi-stage build for the Netflix Eureka service-discovery server.
#
# Stage 1 (builder) – compiles the eureka-server Maven module.
# Stage 2 (runtime) – minimal JRE image that runs the fat JAR.
#
# Exposed port : 8761  (Eureka dashboard + registration API)
# Health check : GET /actuator/health
# ─────────────────────────────────────────────────────────────────────────────

# ── Stage 1: Build ───────────────────────────────────────────────────────────
FROM maven:3.9-eclipse-temurin-17-alpine AS builder
WORKDIR /workspace

# Copy all module POMs first so Maven can resolve the dependency graph.
# This layer is cached unless a pom.xml changes, making rebuilds faster.
COPY pom.xml .
COPY api-gateway/pom.xml api-gateway/
COPY auth-service/pom.xml auth-service/
COPY user-service/pom.xml user-service/
COPY product-service/pom.xml product-service/
COPY order-service/pom.xml order-service/
COPY review-service/pom.xml review-service/
COPY payment-service/pom.xml payment-service/
COPY eureka-server/pom.xml eureka-server/
COPY config-server/pom.xml config-server/

# Pre-download dependencies into the Maven cache (cached layer).
RUN mvn -pl eureka-server dependency:go-offline -B --no-transfer-progress || true

# Copy source and compile the eureka-server module only.
COPY eureka-server/src eureka-server/src
RUN mvn -pl eureka-server package -DskipTests -B --no-transfer-progress

# ── Stage 2: Runtime ─────────────────────────────────────────────────────────
FROM eclipse-temurin:17-jre-alpine
WORKDIR /app

# Copy the Spring Boot fat JAR produced by Stage 1.
COPY --from=builder /workspace/eureka-server/target/*.jar app.jar

# Eureka default port — all services register at http://eureka-server:8761/eureka
EXPOSE 8761

# Launch the Eureka Server.
ENTRYPOINT ["java", "-jar", "app.jar"]
